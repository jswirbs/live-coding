  d9 $ chop 16 $ loopAt 8 $ s "g6" # n 6 # speed "-1" # cutoff 2000 # hcutoff 1000 # rvb (segment 16 $ range 0 0.8 sine) 0.5 # gain (segment 16 $ range 1 0.8 sine)


