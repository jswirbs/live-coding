d6 $ sometimes (ghost) $ n "[0(9,16)]" # s "XORE_hats" # n 3 # gain (range 0.75 0.8 rand)
d6 $ sometimes (ghost) $ n "[0(9,16)]" # s "XORE_hats" # n 4 # gain (range 0.75 0.8 rand)
d6 $ sometimes (ghost) $ n "[0(9,16)]" # s "XORE_hats" # n 14 # gain (range 0.75 0.8 rand)
