bpm 133


-- f eeeeee
d2 $ slice "12 3 ~ ~" "0 [~ 0] ~ ~" $ s "SOPHIE_subs" # n "8 7 ~ ~"


d1 $ s "SOPHIE_kicks_dry*4" # n 1
d1 $ s "techno_kicks*4" # n 1
