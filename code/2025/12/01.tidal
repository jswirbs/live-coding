  xfadeIn 4 16 $ (1 <~) $ n ("gs(5,8)" - ((1 ~>) $ "[0 1]/16")) # octave 2 # s "warsawbass" # room 0 # cutoff (range 2400 3000 perlin) # distort (range 0 0.2 perlin) # gain "0 0.95@3" # orbit 3

