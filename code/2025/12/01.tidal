  d7 $ s "~ ~ [~ ~ techno_perc ~ ~ ~ ~ ~] ~" # n 2
  d7 $ s "~ ~ [~ techno_perc] ~" # n 2 # gain 0.78 # cutoff 800 # room 0.2





bpm 133





do
