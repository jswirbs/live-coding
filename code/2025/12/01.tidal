d5 $ loopAt 2 $ gap 4 $ s "techno_perc_loops" # n 14 # gain 0.95




  d6 $ (0.125 ~>) $ slice 128 "24*4" $ s "trancey_synth_loops" # n 17 # gain 0.77 # cutoff 3000 # room 0.1 # speed "<-1 1>"
  d6 $ (0.125 ~>) $ slice 128 "~@3 72" $ s "trancey_synth_loops" # n 17 # gain 0.77 # cutoff 7000 # room 0.1 # note "1" -- # speed "<-1 1>"

