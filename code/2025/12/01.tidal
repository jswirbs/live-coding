  d8 $ chop 64 $ slow 4 $ s "techno_textures" # n 7 # gain 1 # distort (slow 2 $ (0.13 * (run 64 / 64))) # hcutoff 700 # cutoff 1300
  d8 silence


  -- c'min g'min
