d6 $ stutter 2 (1/8) $ slice 64 ("0 2 4 6" + 26) $ slow 8 $ s "UMRU_chord_loops" # n 10 # cutoff (slow 24 $ range 800 3000 sine) # gain 0.9 # distort (segment 8 $ slow 4 $ range 0 0.2 saw)




  d7 $ n "[c*8]/3" # s "m1" # midichan 7 # stack [(ccn 22 # ccv (segment 8 $ range 40 90 rand))]
  d7 $ n "c(5,8)" # s "m1" # midichan 7 # stack [(ccn 22 # ccv (segment 8 $ range 40 90 rand)), (ccn 10 # ccv 84)]
  d7 silence


  d7 $ n "[c*4 b4*4]/16" # s "moogbass" # gain 0.85
  d7 $ n "[c*4 b4*4]/16" # s "supersaw" # pitch1 3 # cutoff 5000 # gain 0.7 # octave 6 # sustain 3.83
  d7 silence

  d7 $ n "[c*64 b4*64]/16" # s "moogbass" # gain (range 0.85 0.5 rand) # distort (fast 2 $ range 0.1 0.3 perlin) # room 0.4 # size 0.9
  d7 $ n "[c*128 b4*128]/16" # s "moogbass" # gain (range 0.85 0.5 rand) # distort (fast 2 $ range 0.1 0.3 perlin) # room 0.4 # size 0.9
