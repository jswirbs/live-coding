  d6 $ (0.125 ~>) $ slice 64 "~@3 1" $ s "trancey_synth_loops" # n 20 # gain 0.77 # cutoff 3000 # room 0.1 # speed "<-1 1>"

  d6 $ (0.125 ~>) $ slice 64 "~@3 [4 16 ~ ~]" $ s "nebula" # n 6 # gain 0.77 # cutoff 3000 # room 0.1 # speed "<-1 1>"
  d6 silence


  d6 $ s "[~@7 techno_fx]/2" # n 3 # cutoff 2000 # room 0 # waveloss 30 # distort 0.12
  d6 $ n "[~@7 c]" # s "m1" # midichan 3
  d6 $ n "[~@15 c]/2" # s "m1" # midichan 3


  d6 $ chop 64 $ slow 4 $ s "techno_textures" # n 10 # gain 1.1 # distort (slow 2 $ (0.13 * (run 64 / 64)))



d6 $ stutter 2 (1/8) $ slice 32 ("0 1 2 3" + 0) $ slow 8 $ s "UMRU_chord_loops" # n 10 # cutoff 1000
d6 $ stutter 2 (1/8) $ slice 32 ("0 1 2 3" + 8) $ slow 8 $ s "UMRU_chord_loops" # n 10 # cutoff 1000
d6 $ stutter 2 (1/8) $ slice 32 ("0 1 2 3" + 24) $ slow 8 $ s "UMRU_chord_loops" # n 10 # cutoff 1000
