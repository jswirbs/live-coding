d3 $ n "[c*8]/3" # s "m1" # midichan 2 # ccv 34 # ccn 10
-- B G#
d3 $ n "[c*8]/3" # s "m1" # midichan 2 # ccv "[35 32]/16" # ccn 10
d3 silence


  d4 $ n "c*4" # s "m1" # midichan 4
  d4 $ n "c(5,8)" # s "m1" # midichan 4
  d4 $ (0.125 ~>) $ n "c*4" # s "m1" # midichan 4
