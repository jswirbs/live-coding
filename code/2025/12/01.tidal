    d9 $ s "[~@15 [soshats*4]]/4" # n (choose[0,2,3,5,7,10]) # octave 3 # distort 0.3 # gain 0.8 # squiz (range 2 3.3 perlin) # waveloss 18 # sustain 0.2 # rvb 0.2 "[~@15 [0 0 0.8 0.98]]/4"

      d10 $ s "[~ soshats] ~@3" # n (choose[0,2,3,5,7,10]) # octave 3 # distort 0.3 # gain 0.8 # squiz (range 2 3.3 perlin) # waveloss 18 # sustain 0.2



    d7 $ s "~ ~ [~ default] ~" # n (choose[0,2,3,5,7,10,12]) # octave 6 # distort 0.1 # gain 0.75 # waveloss 6
    d7 $ s "[~ default] ~@3" # n (choose[0,2,3,5,7,10,12]) # octave 6 # distort 0.1 # gain 0.75 # waveloss 6
    d7 $ s "[~ default] ~@3" # n (choose[0,2,3,5,7,10,12]) # octave 6 # sustain 0.16 # distort 0.1 # gain 0.65 # waveloss 25 # rvb 0.5 0.97

    d7 $ s "[~ moogbass] ~@3" # n (choose[0,2,3,5,7,10,12]) # octave 6 # sustain 0.16 # distort 0.1 # gain 0.65 # waveloss 20 # rvb 0.5 0.97
    d7 $ s "[~ moogbass] ~@3" # n (choose[0,2,3,5,7,10,12]) # octave 6 # sustain 1 # tremolo 8 1 # distort 0.1 # gain 0.65 # waveloss 20 # rvb 0.5 0.95
    d7 silence













  do
    d5 silence
    xfadeIn 1 16 $ s "techno_kicks*4" # n 2 # djf 0.7
    xfadeIn 7 16 $ s "~ ~ [~ techno_perc] ~" # n 2 # gain 0.7 # cutoff 500 # room 0.8 # size (slow 8 $ range 0.8 1 saw) # orbit 6



  d6 silence



    d1 silence

  do
    d1 silence
    d2 $ s "[~ UMRU_snares]*2" # n 28 # triode 2 # gain 0.85 # triode 4
    -- B G#
    d3 $ n "[c*8]/3" # s "m1" # midichan 2 # ccv "[35 32]/16" # ccn 10
    d3 $ n "[c*8]/3" # s "m1" # midichan 2 # ccv "[34 32]/16" # ccn 10
    d3 $ n "[c*8]/3" # s "m1" # midichan 2 # stack [(ccv "[34 32]/16" # ccn 10), (ccv (slow 24 $ range 48 64 sine) # ccn 3)]
    d5 $ loopAt 2 $ gap 4 $ s "techno_perc_loops" # n 14 # gain 0.95
    xfadeIn 5 16 $ loopAt 2 $ chop 2 $ s "techno_perc_loops" # n 14 # gain 0.95
    -- c'min g'min
    d6 $ s "[~ techno_synth_one_shots] ~@3" # n "[8 11]/16" # gain 0.95




  do
    d1 $ s "[techno_kicks*14@7 techno_kicks*4]/4" # n 2 # room 0.05
    d5 $ loopAt 2 $ chop 2 $ s "techno_perc_loops" # n 14 # gain 0.95
    d7 $ s "~ ~ [~ techno_perc] ~" # n 2 # gain 0.78 # cutoff 800 # room 0.2 # size ((1 <~) $ slow 8 $ range 0 0.99 saw)
    d9 $ s "[~@15 [acid91*4]]/4" # n (choose[0,2,3,5,7,10]) # octave 5 # distort 0.3 # gain 0.7 # rvb 0.3 "[~@15 [0 0 0.8 0.98]]/4" # waveloss 30





